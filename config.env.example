# Copy to config.env and fill in.
# Note: venv lives in .env/, so we use config.env instead of .env for env vars.

# --- App ---
EFLUX_ENV=dev
EFLUX_LOG_LEVEL=INFO
EFLUX_SECRET_KEY=change-me-to-a-long-random-string

# --- Database ---
# Default — SQLite, no extra setup needed:
EFLUX_DB_URL=sqlite+aiosqlite:///./eflux_dev.db

# Postgres (uncomment when running it locally):
# EFLUX_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eflux

# --- Redis (native Redis on Windows) ---
EFLUX_REDIS_URL=redis://localhost:6379/0

# --- Market clock ---
EFLUX_MARKET_SPEED=1.0          # 1.0 = realtime, 10.0 = 10x, 100.0 = 100x
EFLUX_MARKET_TICK_SEC=1.0       # base tick in sim seconds
EFLUX_SITE_TIMEZONE=America/Los_Angeles  # CAISO/SP15 local time for PV/load daily profiles
EFLUX_MARKET_REGION=caiso_sp15
EFLUX_EXTERNAL_MARKET_NODE=TH_SP15_GEN-APND
EFLUX_EXTERNAL_MARKET_TRANSACTION_FEE=2.0
EFLUX_SITE_DEFAULT_LAT=34.05
EFLUX_SITE_DEFAULT_LON=-118.25
EFLUX_SITE_WIND_LAT=33.90
EFLUX_SITE_WIND_LON=-116.60

# --- Auth ---
EFLUX_MAGIC_LINK_TTL_MIN=15
EFLUX_SESSION_TTL_DAY=30
EFLUX_API_KEY_PREFIX=eflux_
EFLUX_ADMIN_EMAILS=

# --- LLM (Phase 6, optional) ---
EFLUX_LLM_PROVIDER=opencode
EFLUX_LLM_KEY_FILE=key.txt
# OpenAI-compatible endpoint; the client appends /chat/completions.
# e.g. https://opencode.ai/zen/go/v1
EFLUX_LLM_BASE_URL=
# Lower-cost default for strict backtests; keep key.txt as the API key source.
EFLUX_LLM_MODEL=deepseek-v4-pro

# --- Event bus backend: "memory" (default) or "redis" ---
EFLUX_BUS_BACKEND=memory

# --- Reflective LLM agent (live calls need LLM creds above; otherwise demo uses fallback) ---
EFLUX_REFLECTIVE_ENABLED=false
EFLUX_REFLECTIVE_INTERVAL_TICKS=60

# --- CORS (for frontend dev) ---
EFLUX_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
